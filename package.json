{
  "name": "skillforge",
  "version": "0.1.0",
  "description": "Compile successful agent traces into reusable skills for OpenClaw and custom agents.",
  "type": "module",
  "bin": {
    "skillforge": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc -p tsconfig.json",
    "test": "vitest run",
    "dev": "tsx src/cli.ts"
  },
  "keywords": [
    "agents",
    "openclaw",
    "automation",
    "skills",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
